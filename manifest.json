{
  "name": "Cookie",
  "description": "Send cookie in whitelist to server side for other applications",
  "version": "1.1",
  "manifest_version": 3,
  "permissions": [
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_icon": "cookie.png",
    "default_popup": "options.html",
    "default_title": "Cookie 设置"
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "js/content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}